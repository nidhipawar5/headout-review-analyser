# 1. Get free Gemini key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# 2. Get free Resend key: https://resend.com (100 emails/day, no card)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 3. For local test use onboarding@resend.dev (delivers only to your Resend account email)
#    For real recipients, verify a domain at resend.com/domains and use: noreply@yourdomain.com
SENDER_EMAIL=onboarding@resend.dev
